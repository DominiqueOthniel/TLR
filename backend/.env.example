# =============================================
# DÉVELOPPEMENT LOCAL (PostgreSQL local)
# =============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=truck_track

# =============================================
# PRODUCTION (Northflank + Supabase, etc.)
# =============================================
# Utiliser DATABASE_URL (obligatoire en prod) :
# Project Settings → Database → Connection string → URI (mode "Transaction")
# Format : postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# =============================================
# GÉNÉRAL
# =============================================
PORT=3000
# Northflank/Docker : le Dockerfile utilise 8080 par défaut. En local, 3000 reste pratique.
# Si tu déploies sans Docker sur Northflank, mets PORT=8080 dans les variables du service.
# Optionnel : par défaut 0.0.0.0 (Northflank / Docker). En local rarement nécessaire.
# HOST=127.0.0.1
NODE_ENV=development

# DB_SYNCHRONIZE=true  → seulement au 1er déploiement pour créer les tables
# DB_SYNCHRONIZE=false → après que les tables sont créées (sécurité)
DB_SYNCHRONIZE=true

# URL du frontend pour CORS (sans slash final). Les *.netlify.app sont déjà autorisés par regex.
# Domaine custom : https://www.mondomaine.cm
FRONTEND_URL=http://localhost:5173

# Optionnel : origines supplémentaires séparées par des virgules (domaine Netlify custom, staging…)
# ADDITIONAL_CORS_ORIGINS=https://app.example.com,https://staging.example.com
