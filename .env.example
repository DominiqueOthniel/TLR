# =============================================
# DÉVELOPPEMENT LOCAL
# =============================================
# Obligatoire : l’URL du backend Nest (port 3000 par défaut), avec ou sans /api à la fin.
# Si tu mets seulement http://localhost:3000, le front ajoute /api automatiquement.
VITE_API_URL=http://localhost:3000/api

# =============================================
# PRODUCTION (Netlify + Northflank + Supabase)
# =============================================
# Remplacer par l’URL publique du backend Northflank. Exemples valides :
#   VITE_API_URL=https://sia-tlr-api.northflank.app
#   VITE_API_URL=https://sia-tlr-api.northflank.app/api
